# ===============================
# Target / Device
# ===============================
CONFIG_TARGET_ipq40xx=y
CONFIG_TARGET_ipq40xx_generic=y
CONFIG_TARGET_ipq40xx_generic_DEVICE_asus_rt-ac42u=y

# ===============================
# LuCI 基础
# ===============================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-firewall=y

# ===============================
# CPU 频率（保留你原来的）
# ===============================
CONFIG_PACKAGE_kmod-cpufreq=y
CONFIG_PACKAGE_kmod-cpufreq-ipq40xx=y
CONFIG_PACKAGE_kmod-qcom-cpufreq=y
CONFIG_PACKAGE_cpufrequtils=y

# ===============================
# Passwall（官方新版，正确写法）
# ===============================
CONFIG_PACKAGE_luci-app-passwall=y

# Passwall 后端（推荐 sing-box）
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_singbox=y
CONFIG_PACKAGE_sing-box=y

# ===============================
# Passwall 网络 / 防火墙依赖（必须补齐）
# ===============================
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nfnetlink=y
CONFIG_PACKAGE_kmod-nf-conntrack=y

# ===============================
# DNS / 转发组件（常用且稳定）
# ===============================
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_dns2socks=y

# （不推荐继续使用，容易冲突，可选）
# CONFIG_PACKAGE_https-dns-proxy=y
# CONFIG_PACKAGE_pdnsd-alt=y

# ===============================
# 明确禁用的重型组件（保留你的设置）
# ===============================
CONFIG_PACKAGE_xray-core=n
CONFIG_PACKAGE_trojan-plus=n
CONFIG_PACKAGE_haproxy=n
CONFIG_PACKAGE_ipt2socks=n
CONFIG_PACKAGE_v2ray-geoip=n
CONFIG_PACKAGE_v2ray-geosite=n

# ===============================
# LuCI 主题
# ===============================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

CONFIG_PACKAGE_luci-theme-kucat=y
CONFIG_PACKAGE_luci-app-kucat-config=y

# ===============================
# USB（保留）
# ===============================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y

# ===============================
# 工具 / 证书 / 兜底依赖（强烈建议）
# ===============================
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_coreutils-timeout=y

# ===============================
# BusyBox（保留你的）
# ===============================
CONFIG_BUSYBOX_DEFAULT_NOLOGIN=y
CONFIG_BUSYBOX_DEFAULT_FEATURE_SH_IS_NONE=y

# ===============================
# ✅ 关键兜底：防止依赖被裁剪
# ===============================
CONFIG_ALL_NONSHARED=y
